  "aptrust:sameAsDomain": [
    "https://hopkinsmedicine.org/",
    "https://www.hopkinsmedicine.org/",
    "https://www.jhmi.edu/",
    "https://jhmi.edu/"
  ],

  "aptrust:sameAsSocialProfile": [
    "https://www.instagram.com/hopkinsmedicine",
    "https://x.com/HopkinsMedicine",
    "https://www.facebook.com/JohnsHopkinsMedicine",
    "https://www.youtube.com/JohnsHopkinsMedicine",
    "https://www.linkedin.com/company/johns-hopkins-medicine"
  ],

  "aptrust:sameAsAdditionalProfile": [
    {
      "url": "https://mychart.hopkinsmedicine.org/",
      "provider": "Epic MyChart",
      "note": "Official patient portal (vendor-hosted Epic instance)."
    },
    {
      "url": "https://hopkinsmedicine.csod.com/",
      "provider": "Cornerstone OnDemand",
      "note": "Official staff learning-management portal."
    }
  ],

  "aptrust:parentOrganization": {
    "name": "Johns Hopkins University",
    "canonicalDomain": "jhu.edu",
    "url": "https://jhu.edu/"
  },

  "aptrust:relatedOrganization": [
    {
      "name": "Johns Hopkins Medical Institutions",
      "canonicalDomain": "jhmi.edu",
      "url": "https://www.jhmi.edu/",
      "domains": ["https://jhmi.edu/", "https://www.jhmi.edu/"],
      "relationshipType": "shared-medical-institution"
    },
    {
      "name": "Johns Hopkins (alternate brand)",
      "canonicalDomain": "jh.edu",
      "url": "https://www.jh.edu/",
      "domains": ["https://jh.edu/", "https://www.jh.edu/"],
      "relationshipType": "sister-brand"
    }
  ],

  "aptrust:exclusion": [
    {
      "domain": "appointments.hopkinsmedicine-promo.example",
      "reason": "Known phishing variant impersonating MyChart appointment booking."
    }
  ],

  "aptrust:officialMail": {
    "provider": "Microsoft Outlook (shared tenant)",
